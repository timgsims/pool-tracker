# .env.development — Vite loads this automatically when running `npm run dev`.
# Points to the TEST Supabase project so local development never touches live data.
# Copy this file to .env.development and fill in your test project values.
# Never commit .env.development.
#
# Get these from: Supabase Dashboard → your TEST project → Settings → API

VITE_SUPABASE_URL=https://[TEST-PROJECT-REF].supabase.co
VITE_SUPABASE_ANON_KEY=[TEST-ANON-KEY]
VITE_BASE_PATH=/
