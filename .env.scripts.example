# .env.scripts — database connection strings for backup/migration/sync scripts.
# Copy this file to .env.scripts and fill in your values. Never commit .env.scripts.
#
# Get these from: Supabase Dashboard → your project → Settings → Database → Connection string → URI
# Use the "Direct connection" URI (not the pooler) — it looks like:
#   postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# If your password contains special characters, URL-encode them:
#   @ → %40   ! → %21   # → %23   $ → %24   & → %26

LIVE_DB_URI=postgresql://postgres:[PASSWORD]@db.[LIVE-PROJECT-REF].supabase.co:5432/postgres
TEST_DB_URI=postgresql://postgres:[PASSWORD]@db.[TEST-PROJECT-REF].supabase.co:5432/postgres
