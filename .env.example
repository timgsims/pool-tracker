# Copy this to .env and fill in your values from the Supabase project settings

# Supabase → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Set this to /your-repo-name/ for GitHub Pages (include trailing slash)
# Leave as / for local dev
VITE_BASE_PATH=/
